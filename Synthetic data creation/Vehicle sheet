import pandas as pd
from openpyxl import load_workbook
import shutil

DRIVE_FILE = "/content/drive/MyDrive/Car Sales.xlsx"
LOCAL_FILE = "/content/Car Sales.xlsx"

shutil.copy(DRIVE_FILE, LOCAL_FILE)

all_sheets = pd.read_excel(LOCAL_FILE, sheet_name=None)
main = all_sheets["Car Sales.xlsx - car_data"]

# Build Dim_Vehicle
dim_vehicle = pd.DataFrame()

# 1. VehicleKey — convert C_CND_000002 → 101, 102...
dim_vehicle["VehicleKey"] = range(101, 101 + len(main))

# 2. Brand from Company column
dim_vehicle["Brand"] = main["Company"].values

# 3. Model
dim_vehicle["Model"] = main["Model"].values

# 4. BodyType from Body Style column
dim_vehicle["BodyType"] = main["Body Style"].values

# 5. FuelType from Engine column
dim_vehicle["FuelType"] = main["Engine"].values

# 6. Transmission
dim_vehicle["Transmission"] = main["Transmission"].values

# 7. Price
dim_vehicle["Price"] = main["Price ($)"].values

# Write to Dim_Vehicle sheet
wb = load_workbook(LOCAL_FILE)
ws = wb["Dim_Vehicle"]
ws.delete_rows(1, ws.max_row)

for col_idx, col_name in enumerate(dim_vehicle.columns, 1):
    ws.cell(row=1, column=col_idx, value=col_name)

for row_idx, row in enumerate(dim_vehicle.itertuples(index=False), 2):
    for col_idx, value in enumerate(row, 1):
        ws.cell(row=row_idx, column=col_idx, value=value)

wb.save(LOCAL_FILE)
shutil.copy(LOCAL_FILE, DRIVE_FILE)

print("Completed")
print(dim_vehicle.head())
