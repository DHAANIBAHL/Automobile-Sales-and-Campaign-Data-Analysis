print(f"   Unique ChannelKeys: {sorted(fmc['ChannelKey'].unique())}")

# ── Update Fact_TestDrive ─────────────────────────────────────────
ftd = all_sheets["Fact_TestDrive"].copy()
ftd["ChannelKey"] = ftd["ChannelKey"].apply(remap_channel)
print(f"\n✅ Fact_TestDrive: ChannelKey remapped")
print(f"   Unique ChannelKeys: {sorted(ftd['ChannelKey'].unique())}")

# ── Write all affected sheets ─────────────────────────────────────
sheets_to_write = {
    "Dim_Channel":                     dim_channel_fixed,
    "Fact_VehicleSales":               fvs,
    "Fact_MarketingCampaignPerforman": fmc,
    "Fact_TestDrive":                  ftd,
}

wb = load_workbook(LOCAL_FILE)
for sheet_name, df in sheets_to_write.items():
    if sheet_name not in wb.sheetnames:
        wb.create_sheet(sheet_name)
    ws = wb[sheet_name]
    ws.delete_rows(1, ws.max_row)
    for col_idx, col_name in enumerate(df.columns, 1):
        ws.cell(row=1, column=col_idx, value=col_name)
    for row_idx, row in enumerate(df.itertuples(index=False), 2):
        for col_idx, value in enumerate(row, 1):
            ws.cell(row=row_idx, column=col_idx, value=value)

wb.save(LOCAL_FILE)
shutil.copy(LOCAL_FILE, DRIVE_FILE)

# ── Validation ────────────────────────────────────────────────────
print("\n" + "="*55)
print("VALIDATION — ALL CHANNELKEYS IN SYNC")
print("="*55)
valid_keys = set(dim_channel_fixed["ChannelKey"].astype(int))

for name, df in [
    ("Fact_VehicleSales",               fvs),
    ("Fact_MarketingCampaignPerforman", fmc),
    ("Fact_TestDrive",                  ftd),
]:
    fact_keys    = set(df["ChannelKey"].astype(int))
    orphan_keys  = fact_keys - valid_keys
    print(f"\n   {name}")
    print(f"   Rows: {len(df):,}")
    print(f"   All keys valid: {'✅ Yes' if not orphan_keys else f'❌ Orphans: {orphan_keys}'}")
    print(f"   Channel distribution:")
    dist = (
        df["ChannelKey"]
        .value_counts()
        .reset_index()
        .merge(dim_channel_fixed[["ChannelKey","ChannelName"]], on="ChannelKey")
        .sort_values("ChannelKey")
    )
    for _, r in dist.iterrows():
        print(f"      {int(r['ChannelKey']):>4} {r['ChannelName']:<30} {int(r['count']):>6} rows")

print("\n✅ All sheets saved to Drive — Dim_Channel fully synced!")
