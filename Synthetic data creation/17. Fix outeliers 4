# ── New channel pool for reassignment ────────────────────────────
new_channel_pool = dim_channel_fixed["ChannelKey"].astype(int).values

# Old channel pool (17 keys 701–717) → remap to new pool (19 keys 701–719)
# Any row that had old 702 (Facebook/Instagram) randomly gets 702 or 703
# Any row that had old 712 (WhatsApp/SMS) randomly gets 713 or 714
# All other old keys map 1:1 to new keys via this table:
old_to_new_map = {
    701: [701],       # Google Search → Google Search
    702: [702, 703],  # Facebook/Instagram → Facebook OR Instagram (random)
    703: [704],       # YouTube → YouTube
    704: [705],       # Email Campaign → Email Campaign
    705: [706],       # Showroom Walk-in → Showroom Walk-in
    706: [707],       # Auto Expo → Auto Expo
    707: [708],       # TV → TV
    708: [709],       # Radio → Radio
    709: [710],       # Referral → Referral
    710: [711],       # Website → Website
    711: [712],       # Corporate Sales → Corporate Sales
    712: [713, 714],  # WhatsApp/SMS → WhatsApp OR SMS (random)
    713: [715],       # Newspaper → Newspaper
    714: [716],       # Billboard → Billboard
    715: [717],       # Dealer Partner → Dealer Partner
    716: [718],       # Cold Call → Cold Call
    717: [719],       # LinkedIn → LinkedIn
}

def remap_channel(old_key):
    options = old_to_new_map.get(int(old_key), [int(old_key)])
    return int(np.random.choice(options))

# ── Update Fact_VehicleSales ──────────────────────────────────────
fvs = all_sheets["Fact_VehicleSales"].copy()
fvs["ChannelKey"] = fvs["ChannelKey"].apply(remap_channel)
