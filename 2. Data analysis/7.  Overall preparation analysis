# ANALYSIS 6: Data preparation
from statsmodels.tsa.holtwinters import ExponentialSmoothing
from IPython.display import display

sales_time = fvs.merge(dim_date, on="DateKey", how="left")

# 6a Monthly aggregation (trend analysis + forecasting input)
monthly = (
    sales_time.groupby(["Year","Month","MonthName","Quarter"])
    .agg(UnitsSold=("UnitsSold","sum"), Revenue=("SaleAmount","sum"))
    .reset_index().sort_values(["Year","Month"])
)

monthly["Period"] = monthly["Year"].astype(str) + "-" + monthly["Month"].astype(str).str.zfill(2)

# 6b Quarterly aggregation (executive-level performance tracking)
quarterly = (
    sales_time.groupby(["Year","Quarter"])
    .agg(UnitsSold=("UnitsSold","sum"), Revenue=("SaleAmount","sum"))
    .reset_index().sort_values(["Year","Quarter"])
)

quarterly["QoQ_Growth%"] = quarterly["Revenue"].pct_change().mul(100).round(2)

# 6c Seasonality analysis (monthly behavior vs annual average)
month_order = ["January","February","March","April","May","June",
               "July","August","September","October","November","December"]

month_avg = (
    monthly.groupby("MonthName")
    .agg(AvgUnits=("UnitsSold","mean"), AvgRevenue=("Revenue","mean"))
    .reset_index()
)

month_avg["MonthName"] = pd.Categorical(month_avg["MonthName"], categories=month_order, ordered=True)
month_avg = month_avg.sort_values("MonthName")

month_avg["VsAvg%"] = (
    (month_avg["AvgUnits"] - month_avg["AvgUnits"].mean()) /
    month_avg["AvgUnits"].mean() * 100
).round(1)

# 6d Weekday vs Weekend comparison
day_perf = (
    sales_time.groupby("IsWeekend")
    .agg(UnitsSold=("UnitsSold","sum"), AvgRevenue=("SaleAmount","mean"), Transactions=("SalesKey","count"))
    .reset_index()
)

# 6e Time series preparation for forecasting
ts       = monthly["UnitsSold"].values
hw       = ExponentialSmoothing(ts, trend="add", seasonal="add", seasonal_periods=12).fit()
forecast = hw.forecast(6)
fitted   = hw.fittedvalues

# 6f Forecast accuracy (MAPE)
mape = abs((ts - fitted) / ts).mean() * 100

forecast_df = pd.DataFrame({
    "Month":         [f"Month +{i}" for i in range(1,7)],
    "ForecastUnits": [int(v) for v in forecast],
    "Confidence":    ["High" if mape < 10 else "Moderate"] * 6,
})

next_month   = int(forecast[0])
safety_stock = int(next_month * 0.15)

inv_df = pd.DataFrame({
    "Item":  ["Forecasted Demand","Safety Stock (+15%)","Recommended Order","Lead Time","Action"],
    "Value": [f"{next_month:,} units", f"{safety_stock:,} units",
              f"{next_month+safety_stock:,} units", "45 days", "Place order now"],
})

monthly.index = range(1, len(monthly) + 1)
quarterly.index = range(1, len(quarterly) + 1)
month_avg.index = range(1, len(month_avg) + 1)
day_perf.index = range(1, len(day_perf) + 1)
forecast_df.index = range(1, len(forecast_df) + 1)
inv_df.index = range(1, len(inv_df) + 1)


print("  6.1. Monthly Sales Time Series")
display(
    monthly[["Period","MonthName","Quarter","UnitsSold","Revenue"]]
    .sort_values("Period")
    .style.format({
        "UnitsSold": "{:,}",
        "Revenue": "${:,.0f}"
    })
)

print("  6.2. Quarterly Sales + QoQ Growth")
display(
    quarterly.sort_values(["Year","Quarter"])
    .style.format({
        "UnitsSold": "{:,}",
        "Revenue": "${:,.0f}",
        "QoQ_Growth%": "{:.2f}%"
    })
)

print("  6.3. Monthly Seasonality vs Annual Average")
display(
    month_avg
    .style.format({
        "AvgUnits": "{:.2f}",
        "AvgRevenue": "${:,.0f}",
        "VsAvg%": "{:.2f}%"
    })
)

print("  6.4. Weekday vs Weekend Sales")
display(
    day_perf
    .style.format({
        "UnitsSold": "{:,}",
        "AvgRevenue": "${:,.0f}",
        "Transactions": "{:,}"
    })
)

print(f"  6.5. 6-Month Forecast — MAPE: {mape:.1f}%")
display(
    forecast_df
    .style.format({
        "ForecastUnits": "{:,}"
    })
)

print("  6.6. Inventory Planning Recommendation")
display(inv_df)

