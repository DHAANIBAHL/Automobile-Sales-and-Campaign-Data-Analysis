               marker="o", markersize=6, label="Monthly trend line"),
    plt.Line2D([0],[0], color="red", linestyle="--",
               linewidth=1.2, label=f"Annual avg ({avg_line:.0f} units)"),
]
ax.legend(handles=legend_elements, loc="upper left", fontsize=9)

