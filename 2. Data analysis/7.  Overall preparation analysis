# Chart 2: Holt-Winters Forecast
fig, ax = plt.subplots(figsize=(18, 7))

hist_labels     = monthly["Period"].tolist()
forecast_labels = [f"+{i}mo" for i in range(1, 7)]
all_labels      = hist_labels + forecast_labels
hist_len        = len(ts)
all_x           = list(range(len(all_labels)))

fitted_extended_x = list(range(hist_len)) + [hist_len]
fitted_extended_y = list(fitted)          + [forecast[0]]

forecast_extended_x = list(range(hist_len - 1, hist_len + 6))
forecast_extended_y = [fitted[-1]] + list(forecast)

ax.plot(range(hist_len), ts,
        color="#2E75B6", linewidth=2, label="Actual sales")

ax.plot(fitted_extended_x, fitted_extended_y,
        color="#70AD47", linewidth=1.5, linestyle="--",
        label="Model fit (how well model matches history)")

ax.plot(forecast_extended_x, forecast_extended_y,
        color="#FFC000", linewidth=2.5, linestyle="--",
        marker="o", markersize=7, label="6-month forecast")

ax.axvline(hist_len-0.5, color="red", linestyle=":",
           linewidth=1.2, label="Forecast start")

for i, val in enumerate(ts):
    ax.annotate(f"{int(val):,}",
                xy=(i, val), xytext=(0, 8),
                textcoords="offset points",
                ha="center", va="bottom",
                fontsize=6.5, color="#2E75B6", fontweight="bold")

for i, val in enumerate(fitted):
    ax.annotate(f"{int(val):,}",
                xy=(i, val), xytext=(0, -14),
                textcoords="offset points",
                ha="center", va="top",
                fontsize=6.5, color="#509030", fontweight="bold")

for i, val in enumerate(forecast):
    ax.annotate(f"{int(val):,}",
                xy=(hist_len + i, val), xytext=(0, 10),
                textcoords="offset points",
                ha="center", va="bottom",
                fontsize=9, fontweight="bold", color="#CC8800")

ax.set_xticks(all_x)
ax.set_xticklabels(all_labels, rotation=90, ha="center", fontsize=7.5)

ax.axvspan(hist_len-0.5, len(all_x)-0.5,
           alpha=0.08, color="#FFC000", label="Forecast region")

ax.set_title("Holt-Winters 6-Month Demand Forecast",
             fontsize=14, fontweight="bold")
ax.set_xlabel("Month / Forecast Period", fontsize=11)
ax.set_ylabel("Units Sold", fontsize=11)
ax.margins(y=0.30)
ax.legend(loc="upper left", fontsize=9)
ax.grid(axis="x", alpha=0.2)
plt.tight_layout()
plt.savefig("/content/a6_chart2_forecast.png", dpi=150, bbox_inches="tight")
plt.show()

# Chart 3: Seasonality
from matplotlib.patches import Patch

fig, ax = plt.subplots(figsize=(13, 6))
avg_line   = month_avg["AvgUnits"].mean()
bar_colors = ["#70AD47" if v >= 0 else "#2E75B6" for v in month_avg["VsAvg%"]]

bars = ax.bar(month_avg["MonthName"], month_avg["AvgUnits"],
              color=bar_colors, alpha=0.85, zorder=2)

ax.plot(month_avg["MonthName"], month_avg["AvgUnits"],
        color="#1F3864", linewidth=2, marker="o",
        markersize=6, zorder=3, label="_nolegend_")

