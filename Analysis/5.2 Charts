# Funnel charts
import matplotlib.pyplot as plt
import matplotlib.patches as FancyBboxPatch
import numpy as np

# Data from Fact_MarketingCampaignPerforman
total_imp   = fmc["Impressions"].sum()
total_leads = fmc["Leads"].sum()
total_tds   = fmc["TestDrives"].sum()
total_book  = fmc["Bookings"].sum()

stages = ["Impressions", "Leads", "Test Drives", "Bookings"]
values = [total_imp, total_leads, total_tds, total_book]
colors = ["#2E75B6", "#F4A261", "#70AD47", "#FFC000"]

# Conversion rates between stages
conv_rates = [
    100,
    total_leads / total_imp  * 100,
    total_tds   / total_leads * 100,
    total_book  / total_tds   * 100,
]

fig, ax = plt.subplots(figsize=(10, 9))
ax.set_xlim(0, 10)
ax.set_ylim(0, 10)
ax.axis("off")

n       = len(stages)
height  = 9.5 / n          # height of each trapezoid
max_w   = 9.0               # widest point (top)
min_w   = 1.5               # narrowest point (bottom)

for i, (stage, val, color, rate) in enumerate(zip(stages, values, colors, conv_rates)):
    # Each layer gets narrower going down
    top_w    = max_w - (max_w - min_w) * (i / n)
    bot_w    = max_w - (max_w - min_w) * ((i + 1) / n)
    top_y    = 10 - i * height
    bot_y    = 10 - (i + 1) * height

    top_left  = (5 - top_w / 2, top_y)
    top_right = (5 + top_w / 2, top_y)
    bot_right = (5 + bot_w / 2, bot_y)
    bot_left  = (5 - bot_w / 2, bot_y)

    # Draw trapezoid
    trap = plt.Polygon(
        [top_left, top_right, bot_right, bot_left],
        closed=True,
        facecolor=color,
        edgecolor="white",
        linewidth=2,
        alpha=0.92,
        zorder=2,
    )
    ax.add_patch(trap)

    # Stage label — centre of trapezoid
    mid_y = (top_y + bot_y) / 2
    ax.text(5, mid_y + 0.10,
            stage,
            ha="center", va="center",
            fontsize=13, fontweight="bold", color="white", zorder=3)

    # Value below stage name
    ax.text(5, mid_y - 0.28,
            f"{val:,.0f}",
            ha="center", va="center",
            fontsize=11, color="white", zorder=3)

    # Conversion rate on the right side (except first stage)
    if i > 0:
        ax.text(5 + top_w / 2 + 0.15, top_y - 0.10,
                f"↓ {rate:.1f}% from previous",
                ha="left", va="center",
                fontsize=8.5, color="#444444", style="italic", zorder=3)

ax.set_title("Marketing Campaign Conversion Funnel\n"
             "Impressions → Leads → Test Drives → Bookings",
             fontsize=14, fontweight="bold", pad=12)

plt.tight_layout()
plt.savefig("/content/a3_funnel_proper.png", dpi=150, bbox_inches="tight")
plt.show()

