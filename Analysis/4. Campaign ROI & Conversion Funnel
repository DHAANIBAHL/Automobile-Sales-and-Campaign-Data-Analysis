# Chart 4: Cost vs Revenue
fig, ax = plt.subplots(figsize=(11, 5))

x = range(len(type_roi))

cost_bars = ax.bar([i-0.2 for i in x], type_roi["TotalCost"],
                   width=0.4, label="Cost", color="#FF0000", alpha=0.7)

rev_bars = ax.bar([i+0.2 for i in x], type_roi["TotalRevenue"],
                  width=0.4, label="Revenue", color="#70AD47", alpha=0.7)

for bar, val in zip(cost_bars, type_roi["TotalCost"]):
    ax.text(bar.get_x() + bar.get_width() / 2,
            bar.get_height() + bar.get_height() * 0.01,
            f"${val:,.0f}",
            ha="center", va="bottom",
            fontsize=7, fontweight="bold",
            color="#CC0000", rotation=45)

for bar, val in zip(rev_bars, type_roi["TotalRevenue"]):
    ax.text(bar.get_x() + bar.get_width() / 2,
            bar.get_height() + bar.get_height() * 0.01,
            f"${val:,.0f}",
            ha="center", va="bottom",
            fontsize=7, fontweight="bold",
            color="#2A7A00", rotation=45)

ax.plot([i-0.2 for i in x], type_roi["TotalCost"],
        "o--", color="#CC0000", linewidth=1.5, markersize=5, label="Cost trend")

ax.plot([i+0.2 for i in x], type_roi["TotalRevenue"],
        "o-", color="#2A7A00", linewidth=1.5, markersize=5, label="Revenue trend")

ax.set_xticks(list(x))
ax.set_xticklabels(type_roi["CampaignType"], rotation=20)
ax.set_title("Cost vs Revenue by Campaign Type", fontsize=14, fontweight="bold")

ax.legend()
plt.tight_layout()
plt.show()

print("Analysis 3 complete")
